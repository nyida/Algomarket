# =============================================================================
# Algomarket — Environment Variables
# =============================================================================

# Whale data (SQLite)
WHALE_DB_PATH=./whale_data.db
WHALE_SCRAPER_DIR=~/Desktop/PolymarketAnalysis

# Existing venue API overrides (optional)
POLY_GAMMA_URL=https://gamma-api.polymarket.com
KALSHI_API_URL=https://api.elections.kalshi.com/trade-api/v2

# Dev API auth
ALGOMARKET_API_KEY=algomarket-dev-key

# --- Prediction Market APIs ---

# PolyRouter — unified API for 7 platforms (free open beta)
# Get key: https://polyrouter.io
POLYROUTER_API_KEY=

# SimpleFunctions — Kalshi + Polymarket unified (free during beta, no key for public endpoints)
# Optional key for higher rate limits
SIMPLEFUNCTIONS_API_KEY=
# Legacy alias (supported):
SIMPLECLOCK_API_KEY=

# Dome — orderbooks (EOL April 2026; acquired by Polymarket)
# Get key: https://domeapi.io
DOME_API_KEY=

# PredScope, Manifold, Metaculus — no keys required (public endpoints)

# --- Crypto APIs ---

# CoinPaprika — no key required (20,000 calls/month free)

# CoinGecko — optional key for higher limits (10,000 calls/month free tier)
COINGECKO_API_KEY=

# CoinMarketCap — requires key (10,000 monthly credits)
COINMARKETCAP_API_KEY=

# --- Traditional Finance ---

# FRED (Federal Reserve) — free, unlimited with key
# Get key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# --- Hyperliquid / AI Tools ---

# GoldRush — Hyperliquid ecosystem data
GOLDRUSH_API_KEY=

# =============================================================================
# Legacy (OpenPatch / other — not used by Algomarket core)
# =============================================================================

# DATABASE_URL="postgresql://user:password@localhost:5432/openpatch?schema=public"
# ENCRYPTION_KEY="32-byte-hex-key-for-api-keys"
