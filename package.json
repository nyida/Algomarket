{
  "name": "algomarket",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "lsof -ti:3000 | xargs kill -9 2>/dev/null || true; next dev -p 3000",
    "dev:clean": "lsof -ti:3000 | xargs kill -9 2>/dev/null; rm -rf .next && next dev -p 3000",
    "dev:full": "bash scripts/ensure-background.sh && next dev -p 3000",
    "scrape": "bash scripts/run-scraper.sh",
    "scrape:live": "bash scripts/run-live-scrapers.sh",
    "scrape:live:install": "bash scripts/install-live-launchd.sh",
    "scrape:install": "bash scripts/install-launchd.sh",
    "scrape:install:all": "bash scripts/install-all.sh",
    "scrape:ensure": "bash scripts/ensure-background.sh",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "better-sqlite3": "^11.8.1",
    "framer-motion": "^12.34.0",
    "idb": "^8.0.3",
    "lucide-react": "^0.575.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3"
  }
}
